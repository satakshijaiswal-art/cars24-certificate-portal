# Cars24 Certificate Portal — Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in any keys you want to activate.
# All three are OPTIONAL. The app works fully offline without them —
# employee photos are processed in-browser using @imgly/background-removal.

# remove.bg API key  (https://www.remove.bg/api)
REMOVE_BG_API_KEY=

# PhotoRoom API key  (https://www.photoroom.com/api)
PHOTOROOM_API_KEY=

# Clipdrop API key   (https://clipdrop.co/apis)
CLIPDROP_API_KEY=
