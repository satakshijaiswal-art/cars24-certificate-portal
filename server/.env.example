# Background Removal APIs - Add as many as you want for automatic fallback
# The server will try each API in order and switch to the next when one is exhausted

# 1. Remove.bg (50 free/month)
# Get key: https://www.remove.bg/api
REMOVE_BG_API_KEY=your_remove_bg_key_here

# 2. PhotoRoom (100 free/month)
# Get key: https://www.photoroom.com/api
PHOTOROOM_API_KEY=your_photoroom_key_here

# 3. Clipdrop (100 free credits/month)
# Get key: https://clipdrop.co/apis
CLIPDROP_API_KEY=your_clipdrop_key_here

PORT=3001

# TOTAL FREE CAPACITY: ~250 images/month with all 3 APIs configured!
